{
  "case_id": "SEC-050-valid-credential-reset-grant-flow",
  "contract": "security-model/1",
  "req_ids": ["SEC-050", "SEC-051", "SEC-053"],
  "description": "An admin runs the routine credential-reset flow for a user: a credential-reset grant is minted and a one-time code/URL is returned for the admin to hand off, the admin's own response never carries the resulting credential value or any path to choose it, no secret material appears in the command's argv/env echo, and redemption revokes the target's existing sessions and API keys by default.",
  "input": {
    "command": "waiveo user password-reset",
    "issuing_admin": { "principal_id": "01J8Z3K4N5P6Q7R8S9T0V1W2AD", "role": "admin" },
    "target_user": { "principal_id": "01J8Z3K4N5P6Q7R8S9T0V1W2US" },
    "opt_out_session_revocation": false,
    "argv_capture": ["waiveo", "user", "password-reset", "01J8Z3K4N5P6Q7R8S9T0V1W2US"]
  },
  "expected": {
    "grant": {
      "purpose": "credential-reset",
      "resulting_principal_kind": "user",
      "redemption_mode": "one-time",
      "issued_via": "api"
    },
    "admin_response": {
      "contains_one_time_code_or_url": true,
      "contains_credential_value": false,
      "admin_can_choose_credential_value": false
    },
    "argv_capture_contains_secret": false,
    "on_redemption": {
      "target_totp_enrollment_changed": false,
      "target_sessions_revoked": true,
      "target_api_keys_revoked": true
    }
  }
}
