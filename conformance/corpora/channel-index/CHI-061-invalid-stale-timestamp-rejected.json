      "signatures": [{ "key_id": "ed25519:timestamp-2026-07", "sig": "valid-sig" }]
    },
    "timestamp_max_age_seconds": 900,
    "evaluation_time": 1752623300000,
    "clock_trusted": true
  },
  "expected": {
    "steps": [
      { "step": 1, "name": "timestamp signature", "result": "pass" },
      { "step": 2, "name": "timestamp freshness/rollback", "result": "fail", "error": { "code": "TIMESTAMP_STALE" } }
