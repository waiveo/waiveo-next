{
  "case_id": "RUL-241-mode-single-drops-concurrent-fire",
  "contract": "rules/1",
  "req_ids": ["RUL-240", "RUL-241", "RUL-246"],
  "description": "Under the default single mode, a trigger firing while a run of the same rule is already in progress is dropped and recorded with a skipped disposition; the original in-progress run is unaffected.",
  "input": {
    "rule": {
      "id": "01J8Z3K4N5P6Q7R8S9T0V1RULD",
      "mode": "single",
      "triggers": [{ "type": "state", "entity_id": "01J8Z3K4N5P6Q7R8S9T0V1W2Z2", "to": ["motion"] }],
      "actions": [{ "type": "delay", "duration_seconds": 20 }, { "type": "device_command", "entity_id": "01J8Z3K4N5P6Q7R8S9T0V1W2Z2", "command": "power_on" }]
    },
    "events": [
      { "seq": 1, "t_ms": 0, "kind": "trigger_fires", "run_id": "run-1" },
      { "seq": 2, "t_ms": 5000, "kind": "trigger_fires", "note": "run-1 is still mid-delay (only 5s of the 20s delay elapsed)" }
    ]
  },
  "expected": {
    "results": [
      { "seq": 1, "run_started": "run-1", "disposition": "ran" },
      { "seq": 2, "run_started": null, "disposition": "skipped", "reason": "mode single drops a new firing while a run is in progress" }
    ],
    "run-1_completes_uninterrupted": true
  }
}
