{
  "case_id": "REL-094-valid-telemetry-latest-only-heartbeat-superseded",
  "contract": "relay/1",
  "req_ids": ["REL-094", "REL-104"],
  "description": "Two device.heartbeat entries for the same device queue while disconnected, seq 2001 and seq 2002. Because device.heartbeat is latest-only, the relay discards the older, superseded seq 2001 entry before ever pushing it — this discard MUST NOT generate a loss marker and MUST NOT be counted in any marker's dropped_counts_by_schema, unlike a durable-class drop.",
  "input": {
    "buffered_entries_same_device": [
      { "seq": 2001, "schema": "device.heartbeat", "payload": { "device_id": "01J8Z3K4N5P6Q7R8S9T0V1W2YA", "power_state": "on", "app_state": "idle", "now_playing_content_id": null } },
      { "seq": 2002, "schema": "device.heartbeat", "payload": { "device_id": "01J8Z3K4N5P6Q7R8S9T0V1W2YA", "power_state": "on", "app_state": "playing", "now_playing_content_id": "01J8Z3K4N5P6Q7R8S9T0V1W2X6" } }
    ],
    "telemetry_push": {
      "type": "telemetry.push",
      "relay_id": "01J8Z4K4N5P6Q7R8S9T0V1W3A1",
      "body": {
        "entries": [
          { "seq": 2002, "schema": "device.heartbeat", "payload": { "device_id": "01J8Z3K4N5P6Q7R8S9T0V1W2YA", "power_state": "on", "app_state": "playing", "now_playing_content_id": "01J8Z3K4N5P6Q7R8S9T0V1W2X6" } }
        ],
        "loss_markers": []
      }
    }
  },
  "expected": {
    "seq_2001_discarded": true,
    "seq_2001_pushed": false,
    "loss_marker_generated": false,
    "dropped_counts_by_schema_includes_device_heartbeat": false,
    "app_peer_final_view_of_device": { "power_state": "on", "app_state": "playing", "now_playing_content_id": "01J8Z3K4N5P6Q7R8S9T0V1W2X6" }
  }
}
